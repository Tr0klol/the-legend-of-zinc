 >= 30:\n        basic.show_icon(IconNames.CONFUSED)\n    else:\n        basic.show_icon(IconNames.HEART)\n\n\n    if risk >= 80:\n        music.play(\n            music.tone_playable(Note.A, music.beat(BeatFraction.WHOLE)),\n            music.PlaybackMode.UNTIL_DONE\n        )\n    elif risk >= 60:\n        music.play(\n            music.tone_playable(Note.C, music.beat(BeatFraction.WHOLE)),\n            music.PlaybackMode.UNTIL_DONE\n        )\n\n    basic.pause(2000)\n","pxt.json":"{\n    \"name\": \"send - Copy\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}},{"timestamp":1769681826793,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"$.CJ4j:Z!?kH_*j2}-d:\">time_ms</variable><variable id=\")DA@5y=)Rv:j@Lenn-mi\">temp</variable><variable id=\"t4PQYjt7%oPUks#j^W0Q\">soil</variable><variable id=\"IqVQ9IYB?.s#2|s`3Na3\">gas</variable><variable id=\"WOjdT+RbxKVqwAed/{{l\">light_val</variable><variable id=\"fR9~9p~HMe}$#+PL).YQ\">uv</variable><variable id=\"F!OwDaU`fItN+s1S^$s|\">risk</variable><variable id=\"[D1.V$9`QF1j0v$M]/;Z\">line</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let time_ms: number;\" numlines=\"1\" declaredvars=\"time_ms\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let temp: number;\" numlines=\"1\" declaredvars=\"temp\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let soil: number;\" numlines=\"1\" declaredvars=\"soil\"></mutation><next><