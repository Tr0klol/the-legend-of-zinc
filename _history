ow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"","README.md":"","main.py":"serial.write_line(\"time_ms,temp,gas,soil,light,uv,flame,risk\")\n\nwhile True:\n    time_ms = control.millis() / 1000\n    temp = pins.analog_read_pin(AnalogPin.P0)\n    soil = pins.analog_read_pin(AnalogPin.P1)\n    gas = pins.analog_read_pin(AnalogPin.P2)\n    light_val = pins.analog_read_pin(AnalogPin.P3)\n    uv = pins.analog_read_pin(AnalogPin.P4)\n    flame = pins.analog_read_pin(AnalogPin.P5)\n\n    # realistic risk calculation\n    risk = 0\n\n    # temperature risk (0–30)\n    if temp < 400:\n        risk += 0\n    elif temp < 600:\n        risk += 10\n    elif temp < 800:\n        risk += 20\n    else:\n        risk += 30\n\n    # soil moisture risk (dry = high risk, 0–25)\n    if soil < 200:\n        risk += 25\n    elif soil < 400:\n        risk += 15\n    elif soil < 600:\n        risk += 5\n\n    # gas risk (high = dangerous, 0–25)\n    if gas > 750:\n        risk += 25\n    elif gas > 600:\n        risk += 15\n    elif gas > 450:\n        risk += 5\n\n    # light risk (very high light = small risk, 0–10)\n    if light_val > 900:\n        risk += 10\n    elif light_val > 700:\n        risk += 5\n\n    # UV risk (high UV = small risk, 0–10)\n    if uv > 900:\n        risk += 10\n    elif uv > 700:\n        risk += 5\n\n    # flame detection (optional extra risk)\n    if flame > 300:\n        risk += 20\n\n    # write serial line\n    line = (\n        str(time_ms) + \",\" +\n        str(temp) + \",\" +\n        str(soil) + \",\" +\n        str(gas) + \",\" +\n        str(light_val) + \",\" +\n        str(uv) + \",\" +\n        str(flame) + \",\" +\n        str(risk)\n    )\n    serial.write_line(line)\n\n    # show icon based on risk\n    if risk >= 60:\n        basic.show_icon(IconNames.ANGRY)\n    elif risk >= 30:\n        basic.show_icon(IconNames.CONFUSED)\n    else:\n        basic.show_icon(IconNames.HEART)\n\n    # play alarm tones based on risk\n    if risk >= 80:\n        music.play(\n            music.tone_playable(Note.A, music.beat(BeatFraction.WHOLE)),\n            music.PlaybackMode.UNTIL_DONE\n        )\n    elif risk >= 60:\n        music.play(\n            music.tone_playable(Note.C, music.beat(BeatFraction.WHOLE)),\n            music.PlaybackMode.UNTIL_DONE\n        )\n\n    basic.pause(2000)\n","pxt.json":"{\n    \"name\": \"send - Copy\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}},{"timestamp":1769518174305,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"OixvTHMky,0#uylusuoe\">time_s</variable><variable id=\"nL)@57/-TUzOT5+7)i{2\">temp</variable><variable id=\"v?t7Ub@(Ocuos#Zvfl@@\">soil</variable><variable id=\"V*JJ[a.R~Oan6@VN}K@D\">gas</variable><variable id=\"T@1qJ1=G0Q,v.*V}rh)7\">light_val</variable><variable id=\"^O{oXWWWM|2Q70L#BnL3\">uv</variable><variable id=\"]5vF6fiSo2f;S]Yx1Lsc\">risk</variable><variable id=\"c$OAyMQkawnD)T4QvFG[\">line</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let time_s: number;\" numlines=\"1\" declaredvars=\"time_s\"></mutation><next><block type