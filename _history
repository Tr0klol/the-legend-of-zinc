uv) + \",\" +\n        str(risk)\n    )\n\n    serial.write_line(line)\n\n    if risk >= 60:\n        basic.show_icon(IconNames.ANGRY)\n    elif risk >= 30:\n        basic.show_icon(IconNames.CONFUSED)\n    else:\n        basic.show_icon(IconNames.HEART)\n\n    if risk >= 80:\n        music.play(music.tone_playable(Note.A, music.beat(BeatFraction.WHOLE)),\n                   music.PlaybackMode.UNTIL_DONE)\n    elif risk >= 60:\n        music.play(music.tone_playable(Note.C, music.beat(BeatFraction.WHOLE)),\n                   music.PlaybackMode.UNTIL_DONE)\n\n","pxt.json":"{\n    \"name\": \"send - Copy\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"SSD1306_OLED\": \"github:pisupply/pxt-oled-ssd1306#v1.2.3\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}},{"timestamp":1768572128130,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"OixvTHMky,0#uylusuoe\">time_s</variable><variable id=\"nL)@57/-TUzOT5+7)i{2\">temp</variable><variable id=\"v?t7Ub@(Ocuos#Zvfl@@\">soil</variable><variable id=\"V*JJ[a.R~Oan6@VN}K@D\">gas</variable><variable id=\"T@1qJ1=G0Q,v.*V}rh)7\">light_val</variable><variable id=\"^O{oXWWWM|2Q70L#BnL3\">uv</variable><variable id=\"]5vF6fiSo2f;S]Yx1Lsc\">risk</variable><variable id=\"c$OAyMQkawnD)T4QvFG[\">line</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let time_s: number;\" numlines=\"1\" declaredvars=\"time_s\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let temp: number;\" numlines=\"1\" declaredvars=\"temp\"></mutation><next><block typ